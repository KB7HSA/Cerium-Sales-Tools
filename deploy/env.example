# Copy to .env in the project root (or run ./deploy/setup-env.sh)

# Public URL users open in the browser (no trailing slash)
APP_URL=http://your-server-ip-or-domain

# HTTP port exposed on the host (default 80)
HTTP_PORT=80

# SQL Server SA password — must meet complexity requirements
SA_PASSWORD=ChangeMe!Aa1StrongPassword

# Database name (created by init script)
DB_NAME=CeriumSalesTools

# Azure AD — required for authentication
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id

# Docker Compose project name
COMPOSE_PROJECT_NAME=cerium-sales

# Optional backend integrations (set in backend/.env after deploy):
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# CONVERTAPI_SECRET=
# PDF_SERVICES_CLIENT_ID=
# PDF_SERVICES_CLIENT_SECRET=
# TDSYNNEX_CLIENT_ID=
# TDSYNNEX_CLIENT_SECRET=
