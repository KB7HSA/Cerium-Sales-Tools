# SQL Server — use localhost when running deploy/ubuntu/setup-database-docker.sh
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=CeriumSalesTools
DB_ENCRYPT=true
DB_TRUST_CERT=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# API server (bind locally; nginx proxies public traffic)
NODE_ENV=production
SERVER_PORT=3000
SERVER_HOST=127.0.0.1

# Public URL users open in the browser (no trailing slash)
CORS_ORIGIN=http://YOUR_VM_IP_OR_DOMAIN

# Azure AD — required for authentication
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id

# Optional integrations
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1
# CONVERTAPI_SECRET=

LOG_LEVEL=info
